# Copy to `.env.local` and paste your Firebase Web SDK config.
#
# Firebase Console → Project settings → Your apps → Web app → firebaseConfig object:
#   apiKey            → NEXT_PUBLIC_FIREBASE_API_KEY
#   authDomain        → NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
#   projectId         → NEXT_PUBLIC_FIREBASE_PROJECT_ID
#   storageBucket     → NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET
#   messagingSenderId → NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
#   appId             → NEXT_PUBLIC_FIREBASE_APP_ID
#
# Required for the app to start Auth: apiKey + authDomain + projectId + appId.
# If authDomain is missing, you get: Firebase: Error (auth/configuration-not-found).
# All six values must come from the SAME web app in Firebase Console.
#
# Deploying on Vercel:
# - Add the same variables under Project → Settings → Environment Variables (Production;
#   add Preview too if you open preview URLs).
# - Trigger a new deployment after adding or changing NEXT_PUBLIC_* values (they are
#   inlined at build time; a runtime-only change without rebuild leaves the old config).
# - Firebase Console → Authentication → Settings → Authorized domains: include your
#   production host (e.g. your-app.vercel.app) and any custom domain, or sign-in can
#   fail or behave differently than on localhost.
#
# Vercel Preview deployments use a different hostname (e.g. …-git-branch-….vercel.app).
# Firebase does not accept wildcards: add each hostname you actually open, or test only
# on the production URL that you already authorized.
#
# If Firestore hangs or never loads on some networks, set (then redeploy):
# NEXT_PUBLIC_FIRESTORE_FORCE_LONG_POLLING=1

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
